# ============================================================
#  Escalation Analyst — Environment Configuration
# ============================================================

# --- Gemini ---
GEMINI_API_KEY=your_gemini_api_key_here
# Model + thinking level. Change anytime, no code edit.
GEMINI_MODEL=gemini-3.5-flash
GEMINI_THINKING=high
# Thinking level for scheduled group reports (cheaper than on-demand default).
GROUP_THINKING=medium

# --- Multi-agent runs (group + master) ---
# How many group-agent Gemini calls run in parallel during a scheduled/master run.
# Raise this as your Gemini tier's rate limit allows.
GROUP_AGENT_CONCURRENCY=4
# Set to "false" to disable all dashboard-managed schedules.
SCHEDULER_ENABLED=true

# --- Delivery (for !analyse command results) ---
RECIPIENT_NUMBER=91XXXXXXXXXX@c.us

# --- Dashboard login ---
DASHBOARD_PORT=8080
DASH_USER=admin
DASH_PASS=change-me-please
DASH_SECRET=set-a-long-random-string

LOG_LEVEL=info
