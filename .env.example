# ============================================================
#  Escalation Analyst — Environment Configuration
# ============================================================

# --- Gemini (media conversion only: image / voice note / PDF → text) ---
GEMINI_API_KEY=your_gemini_api_key_here
# Cheap, multimodal, low-latency. Change anytime, no code edit.
GEMINI_MEDIA_MODEL=gemini-3.1-flash-lite

# --- DeepSeek (escalation reasoning: group + master reports) ---
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# OpenAI-compatible endpoint. First-party = https://api.deepseek.com
# (for a Western-hosted option point this at OpenRouter/DeepInfra and set their model id).
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
# Reasoning depth: high | max. Use 'high' — 'max' spends almost the whole token budget on hidden
# reasoning, truncating reports (blank metrics) and taking ~10 min per report.
DEEPSEEK_REASONING=high
# Output token cap (reasoning shares this budget). Too low truncates the report before its JSON block.
DEEPSEEK_MAX_TOKENS=40000
# Per-request timeout in ms (avoids the SDK's 10-min default hanging a run).
DEEPSEEK_TIMEOUT_MS=150000

# --- Multi-agent runs (group + master) ---
# How many group-agent report calls run in parallel during a scheduled/master run.
# Raise this as your provider's rate limit allows.
GROUP_AGENT_CONCURRENCY=4
# Set to "false" to disable all dashboard-managed schedules.
SCHEDULER_ENABLED=true

# --- Delivery (for !analyse command results) ---
RECIPIENT_NUMBER=91XXXXXXXXXX@c.us

# --- Dashboard login ---
# Bind to localhost in production and expose via nginx (see DEPLOY.md). Use 0.0.0.0 only for
# direct LAN testing without a reverse proxy.
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8080
DASH_USER=admin
# Use STRONG values in production — this single login is shared with whoever uses the dashboard.
DASH_PASS=change-me-please
DASH_SECRET=set-a-long-random-string
# Set to "true" only once the site is served over HTTPS (nginx + certbot), else login can't set a cookie.
COOKIE_SECURE=false

# --- Reconnect resilience ---
# Messages per group pulled on (re)connect to recover any gap from a restart/disconnect. 0 disables.
WA_BACKFILL_LIMIT=50

LOG_LEVEL=info
